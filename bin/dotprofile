#!/usr/bin/env bash
# dotprofile — переключатель риг-профилей (см. docs/specs/2026-07-13-*.md)
set -euo pipefail

DOTFILES="$HOME/dotfiles"
PROFILES="$DOTFILES/profiles"
ACTIVE="$PROFILES/active"
CONTESTED=(hypr gtk-3.0 gtk-4.0 qt5ct qt6ct)

usage() {
    echo "usage: dotprofile switch <name> [--links-only] | menu | status | update <name>" >&2
    exit 1
}

current() { [[ -L "$ACTIVE" ]] && basename "$(readlink -f "$ACTIVE")"; }

list_profiles() {
    find "$PROFILES" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
}

ensure_links() {
    for d in "${CONTESTED[@]}"; do
        ln -sfn "$PROFILES/active/$d" "$HOME/.config/$d"
    done
}

# Цвет рамок окон задаётся конфиг-движком при старте сессии; при горячем
# свитче применяем цвета активного рига runtime-командой (lua: eval hl.config,
# hyprlang: keyword). Источники: colors.conf (matugen ilyamiro) или
# scheme/current.lua (caelestia: primary/onSurfaceVariant).
apply_rig_colors() {
    local name="$1" active="" inactive=""
    local cconf="$PROFILES/$name/hypr/colors.conf"
    local clua="$PROFILES/$name/hypr/scheme/current.lua"
    if [[ -f "$cconf" ]]; then
        active="$(awk -F' = ' '/^\$active_border/{print $2}' "$cconf")"
        inactive="$(awk -F' = ' '/^\$inactive_border/{print $2}' "$cconf")"
    elif [[ -f "$clua" ]] && command -v luajit >/dev/null; then
        local p osv
        read -r p osv < <(luajit -e "local s=dofile('$clua') print(s.primary, s.onSurfaceVariant)" 2>/dev/null) || true
        [[ -n "${p:-}" && -n "${osv:-}" ]] && { active="rgba(${p}e6)"; inactive="rgba(${osv}11)"; }
    fi
    [[ -n "$active" && -n "$inactive" ]] || return 0

    if [[ "$(hypr_provider)" == lua ]]; then
        hyprctl eval "hl.config({
            general = { col = { active_border = '$active', inactive_border = '$inactive' } },
            group = { col = {
                border_active = '$active', border_inactive = '$inactive',
                border_locked_active = '$active', border_locked_inactive = '$inactive',
            } },
        })" >/dev/null || true
    else
        hyprctl keyword general:col.active_border "$active" >/dev/null || true
        hyprctl keyword general:col.inactive_border "$inactive" >/dev/null || true
        hyprctl keyword group:col.border_active "$active" >/dev/null || true
        hyprctl keyword group:col.border_inactive "$inactive" >/dev/null || true
        hyprctl keyword group:col.border_locked_active "$active" >/dev/null || true
        hyprctl keyword group:col.border_locked_inactive "$inactive" >/dev/null || true
    fi

    # fastfetch: акцент рига в конфиг из шаблона (truecolor 38;2;R;G;B)
    local tmpl="$DOTFILES/.config/fastfetch/config.jsonc.template"
    local hex="${active#rgba(}"; hex="${hex#rgb(}"; hex="${hex%)}"; hex="${hex:0:6}"
    if [[ -f "$tmpl" && "$hex" =~ ^[0-9a-fA-F]{6}$ ]]; then
        local r=$((16#${hex:0:2})) g=$((16#${hex:2:2})) b=$((16#${hex:4:2}))
        sed "s/{{ACCENT}}/38;2;$r;$g;$b/g" "$tmpl" > "$DOTFILES/.config/fastfetch/config.jsonc"
    fi

    # Vencord-тема Discord (rig.theme.css в vesktop/equibop): контент по ригу.
    # ilyamiro-вариант генерит его matugen (обновляется со сменой обоев).
    local dsrc
    if [[ "$name" == ilyamiro && -f "$HOME/.cache/matugen/discord-ilyamiro.theme.css" ]]; then
        dsrc="$HOME/.cache/matugen/discord-ilyamiro.theme.css"
    else
        dsrc="$PROFILES/caelestia/discord.theme.css"
    fi
    if [[ -f "$dsrc" ]]; then
        local client
        for client in vesktop equibop Vencord; do
            [[ -d "$HOME/.config/$client/themes" ]] && cp "$dsrc" "$HOME/.config/$client/themes/rig.theme.css"
        done
    fi

    # Obsidian: CSS-сниппет rig-theme в вольте, контент по ригу (как Discord)
    local vault="$HOME/Documents/Obsidian Vault/Shalyn_Vault"
    local osrc
    if [[ "$name" == ilyamiro && -f "$HOME/.cache/matugen/obsidian-ilyamiro.css" ]]; then
        osrc="$HOME/.cache/matugen/obsidian-ilyamiro.css"
    else
        osrc="$PROFILES/caelestia/obsidian.css"
    fi
    if [[ -d "$vault/.obsidian" && -f "$osrc" ]]; then
        mkdir -p "$vault/.obsidian/snippets"
        cp "$osrc" "$vault/.obsidian/snippets/rig-theme.css"
    fi

    # Запущенные GTK-приложения (Thunar и пр.) не перечитывают gtk.css сами —
    # форсим перепарс каскада переключением темы туда-обратно (краткий блик
    # Adwaita, зато цвета применяются без рестарта приложений).
    local gtheme
    gtheme="$(awk -F= '/^gtk-theme-name/{print $2}' "$PROFILES/$name/gtk-3.0/settings.ini" 2>/dev/null)"
    if [[ -n "$gtheme" ]] && command -v gsettings >/dev/null; then
        gsettings set org.gnome.desktop.interface gtk-theme Adwaita 2>/dev/null || true
        sleep 0.2
        gsettings set org.gnome.desktop.interface gtk-theme "$gtheme" 2>/dev/null || true
    fi
}

hypr_provider() {
    hyprctl systeminfo 2>/dev/null | awk -F': ' '/configProvider/{print $2}'
}

# Анимации, как и рамки, живут в конфиг-движке — применяем набор активного
# рига runtime-командами из заранее переведённых файлов профиля.
apply_rig_animations() {
    local name="$1"
    if [[ "$(hypr_provider)" == lua ]]; then
        local chunk="$PROFILES/$name/animations-runtime.lua"
        [[ -f "$chunk" ]] && hyprctl eval "dofile('$chunk')" >/dev/null || true
    else
        local kw="$PROFILES/$name/animations-runtime.keywords" k v
        [[ -f "$kw" ]] || return 0
        while read -r k v; do
            [[ -z "$k" || "$k" == \#* ]] && continue
            hyprctl keyword "$k" "$v" >/dev/null || true
        done < "$kw"
    fi
}

cmd_switch() {
    local name="${1:-}"; [[ -n "$name" ]] || usage
    local links_only="${2:-}"
    [[ -d "$PROFILES/$name" ]] || { echo "no such profile: $name" >&2; exit 1; }
    local old; old="$(current || true)"

    ln -sfn "$name" "$ACTIVE"
    ensure_links

    if [[ "$links_only" != "--links-only" ]]; then
        if [[ -n "$old" && -x "$PROFILES/$old/session.sh" ]]; then
            "$PROFILES/$old/session.sh" stop || true
        fi
        # Провайдер конфига Hyprland (lua/hyprlang) выбирается при старте
        # инстанса и на лету не меняется: reload чужого движка = ошибка.
        if command -v hyprctl >/dev/null; then
            local running target
            running="$(hyprctl systeminfo 2>/dev/null | awk -F': ' '/configProvider/{print $2}')"
            [[ -f "$PROFILES/$name/hypr/hyprland.lua" ]] && target=lua || target=hyprlang
            if [[ -z "$running" || "$running" == "$target" ]]; then
                # Родной движок: вернуть autoreload и перечитать конфиг
                if [[ "$running" == lua ]]; then
                    hyprctl eval 'hl.config({ misc = { disable_autoreload = false } })' >/dev/null || true
                else
                    hyprctl keyword misc:disable_autoreload false >/dev/null || true
                fi
                hyprctl reload || true
            else
                # Кросс-движок: Hyprland следит за файлами, загруженными при
                # старте — правка конфигов неактивного рига вызвала бы reload
                # и ошибку "cannot open hyprland.lua". Глушим autoreload.
                if [[ "$running" == lua ]]; then
                    hyprctl eval 'hl.config({ misc = { disable_autoreload = true } })' >/dev/null || true
                else
                    hyprctl keyword misc:disable_autoreload true >/dev/null || true
                fi
                echo "note: конфиг-движок '$target' != запущенного '$running' — бинды/настройки WM применятся после relogin в сессию '$name'"
            fi
        fi
        [[ -x "$PROFILES/$name/session.sh" ]] && "$PROFILES/$name/session.sh" start
        if command -v hyprctl >/dev/null; then
            apply_rig_colors "$name"
            apply_rig_animations "$name"
        fi
    fi
    echo "active: $name"
}

cmd_menu() {
    local cur choice
    cur="$(current || true)"
    choice="$(list_profiles | sed "s/^${cur}\$/& (active)/" \
        | fuzzel --dmenu --prompt 'profile> ' --lines 4)" || exit 0
    choice="${choice% (active)}"
    [[ -z "$choice" || "$choice" == "$cur" ]] && exit 0
    cmd_switch "$choice"
}

cmd_status() {
    echo "active: $(current || echo '<none>')"
    for d in "${CONTESTED[@]}"; do
        local t; t="$(readlink "$HOME/.config/$d" 2>/dev/null || echo 'NOT A SYMLINK')"
        printf '  %-8s -> %s\n' "$d" "$t"
    done
}

# update: материализуем симлинки в реальные каталоги, чтобы чужой installer
# писал в них, потом снимаем снапшот обратно в профиль и возвращаем симлинки.
# При Ctrl+C/ошибке на любом шаге trap восстанавливает симлинки и прежний
# профиль; снапшот пишется в $d.new и подменяется атомарно, поэтому отмена
# оставляет профиль нетронутым.
# restore вызывается и из trap EXIT (вне области local), поэтому prev — глобальная.
# Best-effort: одна неудача не должна бросить остальные каталоги без симлинков.
UPDATE_PREV=""
restore() {
    [[ -n "$UPDATE_PREV" ]] && ln -sfn "$UPDATE_PREV" "$ACTIVE" || true
    for d in "${CONTESTED[@]}"; do
        if [[ -e "$HOME/.config/$d" && ! -L "$HOME/.config/$d" ]]; then
            chmod -R u+w "$HOME/.config/$d" 2>/dev/null || true
            rm -rf "$HOME/.config/${d:?}" 2>/dev/null || true
        fi
        if [[ ! -e "$HOME/.config/$d" || -L "$HOME/.config/$d" ]]; then
            ln -sfn "$PROFILES/active/$d" "$HOME/.config/$d" || true
        else
            echo "warning: не смог восстановить ~/.config/$d — убери каталог руками и запусти: dotprofile switch $UPDATE_PREV --links-only" >&2
        fi
    done
}

cmd_update() {
    local name="${1:-}"; [[ -n "$name" ]] || usage
    [[ -d "$PROFILES/$name" ]] || { echo "no such profile: $name" >&2; exit 1; }
    UPDATE_PREV="$(current || echo caelestia)"

    trap restore EXIT INT TERM

    ln -sfn "$name" "$ACTIVE"
    for d in "${CONTESTED[@]}"; do
        rm -rf "$HOME/.config/${d:?}"
        cp -a "$PROFILES/$name/$d" "$HOME/.config/$d"
    done
    echo ">>> Каталоги материализованы. Запусти installer профиля '$name'."
    echo ">>> Enter когда installer закончит (или Ctrl+C для отмены):"
    read -r

    for d in "${CONTESTED[@]}"; do
        rm -rf "$PROFILES/$name/${d:?}.new"
        cp -a "$HOME/.config/$d" "$PROFILES/$name/$d.new"
        rm -rf "$PROFILES/$name/${d:?}"
        mv "$PROFILES/$name/$d.new" "$PROFILES/$name/$d"
    done

    trap - EXIT INT TERM
    restore

    # Пост-обработка снапшота (например, вернуть source-строки, которые
    # затирает installer профиля)
    if [[ -x "$PROFILES/$name/post-update.sh" ]]; then
        "$PROFILES/$name/post-update.sh" || echo "warning: post-update.sh завершился с ошибкой" >&2
    fi
    echo "profile '$name' updated; active: $UPDATE_PREV"
}

case "${1:-}" in
    switch) shift; cmd_switch "$@" ;;
    menu)   cmd_menu ;;
    status) cmd_status ;;
    update) shift; cmd_update "$@" ;;
    # Переприменить цвета рамок активного рига (зовётся из matugen-пайплайна
    # после смены обоев)
    colors) apply_rig_colors "$(current || echo caelestia)" ;;
    *) usage ;;
esac
